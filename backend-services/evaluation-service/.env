# Evaluation Service Environment Variables
PORT=8004

# Redis (evaluation-service usa REDIS_HOST, não REDIS_URL)
REDIS_HOST=shared-redis:6379

# SQS (LocalStack)
AWS_SQS_URL=http://localstack:4566/000000000000/ToggleMasterQueue
AWS_SQS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1

# Credenciais AWS (dummy para LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Services URLs (para comunicação entre serviços)
AUTH_SERVICE_URL=http://auth-app:8001
FLAG_SERVICE_URL=http://flag-app:8002
TARGETING_SERVICE_URL=http://targeting-app:8003

# Master Key para gerar API Key automaticamente
MASTER_KEY=admin-secreto-123

# API Key (será gerada automaticamente se vazio)
SERVICE_API_KEY=
